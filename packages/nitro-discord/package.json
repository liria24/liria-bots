{
    "name": "@liria/nitro-discord",
    "version": "0.1.0",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.mts"
        },
        "./discord.js": {
            "import": "./dist/discord.mjs",
            "types": "./dist/discord.d.mts"
        },
        "./nitro-module": {
            "import": "./dist/nitro-module.mjs",
            "types": "./dist/nitro-module.d.mts"
        }
