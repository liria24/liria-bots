{
    "name": "liria-discord-bot",
    "version": "1.0.0",
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "prebuild": "bun run --filter '@liria/nitro-discord' build",
        "build": "nitro build",
        "dev": "nitro dev",
        "preview": "nitro preview",
        "prestart": "drizzle-kit push --force",
        "start": "node ./.output/server/index.mjs",
        "test": "bun test",
        "check": "vp check",
        "check:fix": "vp check --fix"
    },
    "dependencies": {
        "@libsql/client": "^0.17.2",
        "@liria/nitro-discord": "workspace:*",
        "drizzle-orm": "1.0.0-beta.19",
        "http-status-codes": "^2.3.0",
        "nanoid": "^5.1.7",
        "nitro": "3.0.260311-beta",
        "sanitize-html": "2.17.2",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@types/node": "25.5.0",
        "@types/sanitize-html": "2.16.1",
        "consola": "3.4.2",
        "drizzle-kit": "1.0.0-beta.19",
        "taze": "^19.10.0",
        "typescript": "6.0.2",
        "vite": "8.0.2",
        "vite-plus": "^0.1.14"
    },
    "engines": {
        "node": "24"
    },
    "packageManager": "bun@1.3.11"
}
